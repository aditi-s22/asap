# --- Required ---
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/asap-parking

# Required in production (server refuses to boot without these in production).
# In development, insecure built-in fallbacks are used so the app still runs locally —
# but you should still set real values here even in dev.
JWT_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string

# Used for CORS allow-list and the refresh-token cookie. Must match where the frontend is served.
FRONTEND_URL=http://localhost:5173

# --- Optional integrations ---
# Every integration below fails closed when absent: in production it returns a clear
# error (503/403) instead of silently bypassing security; in development it falls back
# to an explicitly-logged simulation/mock that can never act on a real account or charge.

# Razorpay (payments). Without these, dev mode uses a simulated payment flow bound to
# the specific booking/order it was issued for — never a client-fabricated bypass.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary (image uploads). Without these, uploads fall back to local disk storage
# under backend/uploads — fine for local dev, not for a real deployment.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Admin SDK (authentication — email/password, phone OTP, Google sign-in all
# flow through Firebase on the client; this is what lets the backend verify the ID
# token it's handed). Get these three values from Firebase Console > Project Settings
# > Service Accounts > Generate new private key. Without them, POST /auth/firebase-session
# returns 503 ("Authentication service is not configured") — nobody can sign in at all,
# this is required, not optional, once the frontend is also pointed at a Firebase project.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
